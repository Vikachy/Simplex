<Window x:Class="SimplexSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimplexSolver"
        mc:Ignorable="d"
        Title="Симплекс-метод - Решение задач линейного программирования" 
        Height="850" Width="1300"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToOptimalTextConverter x:Key="BoolToOptimalTextConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Логотип и заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="📐" FontSize="28" Margin="0,0,8,0"/>
            <StackPanel>
                <TextBlock Text="СИМПЛЕКС-МЕТОД" FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="Решение задач линейного программирования" FontSize="10" 
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Панель управления -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="12" Margin="0,0,0,16" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="📋 Загрузить вариант 14" Click="LoadExample_Click" 
                        Style="{StaticResource SuccessButton}"/>
                <Button Content="⚡ Решить симплекс-методом" Click="SolveSimplex_Click" 
                        Style="{StaticResource AccentButton}"/>
                <Button Content="🗑️ Очистить" Click="Clear_Click" 
                        Style="{StaticResource InfoButton}"/>
                <Button Content="📊 Экспорт в Excel" Click="ExportToExcel_Click" 
                        Style="{StaticResource InfoButton}"/>
            </StackPanel>
        </Border>

        <!-- Ввод задачи -->
        <GroupBox Grid.Row="2" Header="📝 Постановка задачи" Margin="0,0,0,16"
                  BorderBrush="{StaticResource InfoBrush}" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Тип оптимизации и размеры -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Целевая функция:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbGoal" Width="100" Margin="10,0" Height="28">
                        <ComboBoxItem Content="max →" IsSelected="True" FontWeight="SemiBold"/>
                        <ComboBoxItem Content="min →" FontWeight="SemiBold"/>
                    </ComboBox>
                    <TextBlock Text="Количество переменных:" VerticalAlignment="Center" 
                               Margin="20,0,0,0" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtVariables" Text="3" Width="50" Margin="5,0" Height="24"
                             Style="{StaticResource SmallTextBox}"/>
                    <TextBlock Text="Количество ограничений:" VerticalAlignment="Center" 
                               Margin="20,0,0,0" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtConstraints" Text="4" Width="50" Margin="5,0" Height="24"
                             Style="{StaticResource SmallTextBox}"/>
                    <Button Content="Создать таблицу" Click="CreateTable_Click" 
                            Margin="20,0,0,0" Padding="10,5" Style="{StaticResource InfoButton}"/>
                </StackPanel>

                <!-- Коэффициенты целевой функции -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="F(x) = " FontWeight="SemiBold" VerticalAlignment="Center" FontSize="14"/>
                    <ItemsControl x:Name="icObjective" ItemsSource="{Binding ObjectiveCoefficients}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <TextBox Text="{Binding Value, StringFormat=F2}" 
                                             Width="60" Height="24" VerticalAlignment="Center"
                                             BorderBrush="{StaticResource InfoBrush}" BorderThickness="1"
                                             TextAlignment="Center"/>
                                    <TextBlock Text=" × x" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    <TextBlock Text="{Binding Index}" VerticalAlignment="Center" 
                                               FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text=" +" VerticalAlignment="Center" 
                                               Margin="5,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Подсказка -->
                <TextBlock Grid.Row="2" Text="* Для ввода отрицательных чисел используйте знак '-'"
                           FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"/>
            </Grid>
        </GroupBox>

        <!-- Таблица ограничений -->
        <GroupBox Grid.Row="3" Header="📊 Ограничения" 
                  BorderBrush="{StaticResource SuccessBrush}" BorderThickness="2"
                  Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовки таблицы -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="0,0,0,2" 
                            Background="#E8F5E8" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Ограничение" 
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Тип" 
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Выражение" 
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Значение" 
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Список ограничений -->
                    <ItemsControl Grid.Row="1" x:Name="icConstraints" 
                                  ItemsSource="{Binding Constraints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#C8E6C9" BorderThickness="0,0,0,1" Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                                   VerticalAlignment="Center" FontWeight="SemiBold"/>

                                        <ComboBox Grid.Column="1" SelectedIndex="{Binding TypeIndex}"
                                                  VerticalAlignment="Center" Height="24" Width="50">
                                            <ComboBoxItem Content="≤"/>
                                            <ComboBoxItem Content="="/>
                                            <ComboBoxItem Content="≥"/>
                                        </ComboBox>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" 
                                                    VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <ItemsControl ItemsSource="{Binding Coefficients}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="3,0">
                                                            <TextBox Text="{Binding Value, StringFormat=F2}" 
                                                                     Width="55" Height="24" VerticalAlignment="Center"
                                                                     BorderBrush="{StaticResource SuccessBrush}" 
                                                                     BorderThickness="1" TextAlignment="Center"/>
                                                            <TextBlock Text=" × x" VerticalAlignment="Center" 
                                                                       Margin="3,0,0,0"/>
                                                            <TextBlock Text="{Binding Index}" VerticalAlignment="Center" 
                                                                       FontWeight="Bold" FontSize="12"/>
                                                            <TextBlock Text=" +" VerticalAlignment="Center" 
                                                                       Margin="5,0,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <TextBox Grid.Column="3" Text="{Binding RightHandSide, StringFormat=F2}" 
                                                 Width="100" Height="24" VerticalAlignment="Center"
                                                 BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                                 TextAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </GroupBox>

        <!-- Кнопки управления таблицей -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Добавить ограничение" Click="AddConstraint_Click" 
                    Margin="0,0,10,0" Padding="12,6" Style="{StaticResource SuccessButton}"/>
            <Button Content="➖ Удалить последнее" Click="RemoveConstraint_Click" 
                    Padding="12,6" Style="{StaticResource ErrorButton}"/>
        </StackPanel>

        <!-- Результаты -->
        <TabControl Grid.Row="5">
            <TabItem Header="📈 Симплекс-таблицы">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="spTables" Margin="10">
                        <!-- Таблицы будут добавляться здесь -->
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="✅ Решение">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="White" Padding="20">
                        <StackPanel x:Name="spResults">
                            <StackPanel x:Name="spSolutionContainer">
                                <!-- Решение будет добавляться здесь -->
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="📋 Лог вычислений">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtLog" IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="#FFF5F5F5"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>